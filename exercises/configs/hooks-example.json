{
  "$schema": "https://code.claude.com/docs/schemas/settings.json",
  "_comment": "Module 8 Exercise — Hook Configuration Example",
  "_instructions": "Copy relevant sections into your .claude/settings.json",

  "hooks": {
    "PostToolUse": [
      {
        "_comment": "Auto-format JavaScript files after editing",
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "_comment": "Block dangerous bash commands",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qE 'rm\\s+-rf\\s+/' && echo '{\"decision\": \"block\", \"reason\": \"Blocking dangerous rm -rf / command\"}' && exit 2 || exit 0"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "_comment": "Inject current date and git branch at session start",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Date: $(date '+%Y-%m-%d %H:%M') | Branch: $(git branch --show-current 2>/dev/null || echo 'not a git repo')\""
          }
        ]
      }
    ]
  }
}
